# Notion API Configuration
# Get your API key from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID for the Invoices database
# Find this in the database URL: notion.so/workspace/DATABASE_ID?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public site URL (used for metadata and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
